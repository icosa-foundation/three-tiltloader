{
  "name": "three-tiltloader",
  "version": "0.4.2-alpha.4",
  "description": "Load Tilt Brush / Open Brush files in three.js applications",
  "scripts": {
    "watch": "parcel watch",
    "build": "parcel build --no-cache",
    "test": "npm run build && node --experimental-strip-types --test test/*.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/icosa-gallery/three-tiltloader.git"
  },
  "author": "Icosa Foundation",
  "license": "Apache-2.0",
  "module": "dist/three-tiltloader.module.js",
  "source": "src/TiltLoader.js",
  "types": "src/TiltLoader.d.ts",
  "exports": {
    ".": {
      "types": "./src/TiltLoader.d.ts",
      "import": "./dist/three-tiltloader.module.js",
      "default": "./dist/three-tiltloader.module.js"
    }
  },
  "targets": {
    "types": false
  },
  "bugs": {
    "url": "https://github.com/icosa-foundation/three-tiltloader/issues"
  },
  "homepage": "https://github.com/icosa-foundation/three-tiltloader#readme",
  "devDependencies": {
    "@parcel/transformer-typescript-types": "^2.12.0",
    "@types/three": "^0.164.1",
    "parcel": "latest",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "three": ">=0.139.0"
  },
  "files": [
    "dist",
    "src/*.d.ts",
    "src/*.d.mts",
    "src/*.ts"
  ],
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/icosa"
  },
  "keywords": [
    "three",
    "three.js",
    "viewer",
    "openbrush",
    "tiltbrush",
    "creative",
    "camera",
    "vr",
    "ar",
    "xr"
  ],
  "dependencies": {
    "three-icosa": "https://github.com/icosa-foundation/three-icosa/archive/b405813fd7a00cba5540f00180798b73f7acc9f7.tar.gz"
  }
}
